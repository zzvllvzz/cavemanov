{
  "name": "cavemanov",
  "version": "1.0.0",
  "description": "Ультра-сжатый режим общения на русском. Сокращает ~65-75% токенов при сохранении полной технической точности. Пещерный режим для Claude Code.",
  "author": {
    "name": "zzvllvzz",
    "url": "https://github.com/zzvllvzz"
  },
  "homepage": "https://github.com/zzvllvzz/cavemanov",
  "repository": "https://github.com/zzvllvzz/cavemanov",
  "license": "MIT",
  "keywords": [
    "russian",
    "русский",
    "compression",
    "сжатие",
    "tokens",
    "токены",
    "caveman",
    "пещерный",
    "productivity",
    "ru",
    "skill",
    "hooks",
    "output-style",
    "terse"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/cavemanov-activate.js\"",
            "timeout": 5,
            "statusMessage": "Загрузка пещерного режима..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/cavemanov-mode-tracker.js\"",
            "timeout": 5,
            "statusMessage": "Отслеживание режима..."
          }
        ]
      }
    ]
  }
}
